# ─────────────────────────────────────────────────────────────
# Netlify Functions environment. Copy to `.env` for local `netlify dev`,
# and set the SAME vars in the Netlify dashboard for production.
# NEVER commit the real .env (it is gitignored).
#
# The two SUPABASE *public* values also go in library/config.js (frontend).
# Everything marked SECRET stays server-side only.
# ─────────────────────────────────────────────────────────────

# Supabase — Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # SECRET

# Stripe — test mode keys (Developers → API keys)
STRIPE_SECRET_KEY=sk_test_xxx                      # SECRET
# From `stripe listen` locally, or the dashboard webhook in production
STRIPE_WEBHOOK_SECRET=whsec_xxx                    # SECRET

# Bunny Stream — Stream library → API / Embed settings
BUNNY_STREAM_LIBRARY_ID=123456
BUNNY_TOKEN_AUTH_KEY=your-token-authentication-key # SECRET
BUNNY_CDN_HOSTNAME=vz-xxxxxxxx.b-cdn.net            # optional (HLS url)

# Where the site is served (used for Stripe success/cancel redirects)
SITE_URL=http://localhost:8888
